    "shift_nlr2": {
      "type": "nuracom-shift",
      "settings": {
        "headline": "<p>What if drying clothes indoors was <em>actually solved?</em></p>",
        "text_1": "Not managed. Not tolerated. Not worked around with cheap racks and crossed fingers.",
        "text_2": "What if there was a system that dried your clothes in hours — every time, rain or shine — using less power than a light bulb? A system you could mount once, operate with one touch, and never think about again?",
        "show_divider": true,
        "text_3": "There is. And the technology behind it is simpler than you'd expect.",
        "navy": "#101a32",
        "brand_deep": "#5e0404",
        "brand_accent": "#a8321a",
        "emphasis_color": "#f8a89a",
        "white": "#ffffff"
      }
    },
    "mechanism_nlr2": {
      "type": "nuracom-mechanism",
      "blocks": {
        "ms_1": {
          "type": "mechanism_step",
          "settings": {
            "step_number": "01",
            "icon": "🌀",
            "kicker": "Innovation One",
            "title": "Turbo-Fan Forced Airflow",
            "text_1": "Unlike passive racks that rely on still air to slowly evaporate moisture, Nuracom uses up to 6 ultra-silent turbo fans to force a constant stream of air through your garments. This mimics nature's most effective drying method — a steady breeze — but indoors, on demand, regardless of what's happening outside.",
            "text_2": "The result is dramatically faster drying without the heat damage of a tumble dryer. Your delicates stay intact. Your colours stay true. And your clothes are dry in hours, not days.",
            "highlight_text": "<strong>Key difference:</strong> Forced airflow dries clothes up to 2x faster than passive air drying, while using a fraction of the energy of a tumble dryer."
          }
        },
        "ms_2": {
          "type": "mechanism_step",
          "settings": {
            "step_number": "02",
            "icon": "▲",
            "kicker": "Innovation Two",
            "title": "Ceiling-Mount Heat Capture",
            "text_1": "Hot air rises. It's basic physics, and Nuracom uses it to your advantage. When your rack lifts to ceiling height with one touch, your clothes sit in the warmest zone of any room — where temperatures can be 3–5°C higher than floor level.",
            "text_2": "Combined with the turbo-fan airflow, this creates an optimal drying environment that works with your home's natural convection currents. No extra heating needed. No energy wasted. Just smart engineering.",
            "highlight_text": "<strong>Key difference:</strong> Ceiling mounting utilises wasted warm air that already exists in your home, eliminating the need for energy-hungry heating elements."
          }
        },
        "ms_3": {
          "type": "mechanism_step",
          "settings": {
            "step_number": "03",
            "icon": "✨",
            "kicker": "Innovation Three",
            "title": "UV Disinfection & Hygiene Control",
            "text_1": "Drying clothes isn't just about removing moisture — it's about making them genuinely clean. Nuracom's UV disinfection system (Aero and Stratos models) eliminates bacteria and odour-causing microorganisms during the drying process. The Stratos goes even further with negative ion technology that actively removes dust mites.",
            "text_2": "This means your clothes come off the rack not just dry, but hygienically clean. No musty smell. No hidden bacteria. Just fresh, ready-to-wear clothing, every single time.",
            "highlight_text": "<strong>Key difference:</strong> UV disinfection and negative ion tech mean your clothes are cleaner coming off a Nuracom than out of most tumble dryers."
          }
        }
      },
      "block_order": [
        "ms_1",
        "ms_2",
        "ms_3"
      ],
