{% comment %}
  Nuracom Shift — Bridge from problem-aware to solution-aware.
  Dark, cinematic, hooks the scroll into the mechanism reveal.
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --brand-deep: {{ section.settings.brand_deep }};
    --brand-accent: {{ section.settings.brand_accent }};
    --navy: {{ section.settings.navy }};
    --white: {{ section.settings.white }};
    --max-width: 1120px;
    --section-pad: clamp(60px, 8vw, 120px);
  }
  #shopify-section-{{ section.id }} * { box-sizing: border-box; }
  #shopify-section-{{ section.id }} .nshift { padding: var(--section-pad) 0; background: var(--navy); color: var(--white); position: relative; overflow: hidden; font-family: 'Inter', -apple-system, sans-serif; }
  #shopify-section-{{ section.id }} .nshift::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, {{ section.settings.brand_deep }}26 0%, transparent 60%); pointer-events: none; }
  #shopify-section-{{ section.id }} .nshift__container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; position: relative; z-index: 2; }
  #shopify-section-{{ section.id }} .nshift__inner { max-width: 780px; margin: 0 auto; text-align: center; }
  #shopify-section-{{ section.id }} .nshift__headline { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 4vw, 3rem); font-weight: 700; line-height: 1.2; margin: 0 0 24px; }
  #shopify-section-{{ section.id }} .nshift__headline em { color: {{ section.settings.emphasis_color }}; font-style: italic; }
  #shopify-section-{{ section.id }} .nshift__headline p { margin: 0; }
  #shopify-section-{{ section.id }} .nshift__text { font-size: 1.1rem; color: rgba(255,255,255,0.75); line-height: 1.8; margin: 0 0 16px; }
  #shopify-section-{{ section.id }} .nshift__text:last-child { margin-bottom: 0; }
  #shopify-section-{{ section.id }} .nshift__divider { width: 60px; height: 3px; background: var(--brand-accent); margin: 40px auto; border-radius: 2px; }
  #shopify-section-{{ section.id }} .nshift__reveal { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  #shopify-section-{{ section.id }} .nshift__reveal.is-visible { opacity: 1; transform: translateY(0); }
</style>

<section class="nshift">
  <div class="nshift__container">
    <div class="nshift__inner nshift__reveal">
      <h2 class="nshift__headline">{{ section.settings.headline }}</h2>
      {% if section.settings.text_1 != blank %}
        <p class="nshift__text">{{ section.settings.text_1 }}</p>
      {% endif %}
      {% if section.settings.text_2 != blank %}
        <p class="nshift__text">{{ section.settings.text_2 }}</p>
      {% endif %}
      {% if section.settings.show_divider %}
        <div class="nshift__divider"></div>
      {% endif %}
      {% if section.settings.text_3 != blank %}
        <p class="nshift__text">{{ section.settings.text_3 }}</p>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (function() {
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if (!root) return;
    var els = root.querySelectorAll('.nshift__reveal');
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });
    els.forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "Shift / Transformation",
  "tag": "section",
  "class": "nuracom-shift-section",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "richtext", "id": "headline", "label": "Headline (wrap words in <em> for italic emphasis)", "default": "<p>What if drying clothes indoors was <em>actually solved?</em></p>" },
    { "type": "textarea", "id": "text_1", "label": "Paragraph 1", "default": "Not managed. Not tolerated. Not worked around with cheap racks and crossed fingers." },
    { "type": "textarea", "id": "text_2", "label": "Paragraph 2", "default": "What if there was a system that dried your clothes in hours — every time, rain or shine — using less power than a light bulb? A system you could mount once, operate with one touch, and never think about again?" },
    { "type": "checkbox", "id": "show_divider", "label": "Show accent divider", "default": true },
    { "type": "textarea", "id": "text_3", "label": "Paragraph 3 (curiosity hook)", "default": "There is. And the technology behind it is simpler than you'd expect." },
    { "type": "header", "content": "Colours" },
    { "type": "color", "id": "navy", "label": "Background navy", "default": "#101a32" },
    { "type": "color", "id": "brand_deep", "label": "Ambient glow (brand deep)", "default": "#5E0404" },
    { "type": "color", "id": "brand_accent", "label": "Divider accent", "default": "#a8321a" },
    { "type": "color", "id": "emphasis_color", "label": "Italic emphasis colour", "default": "#f8a89a" },
    { "type": "color", "id": "white", "label": "Text colour", "default": "#ffffff" }
  ],
  "presets": [ { "name": "Shift / Transformation" } ]
}
{% endschema %}
